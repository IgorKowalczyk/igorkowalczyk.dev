  "browserslist": [
    ">0.3%",
    "not ie 11",
    "not dead",
    "not op_mini all"
  ],
  "packageManager": "pnpm@11.4.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/igorkowalczyk/igorkowalczyk.dev.git"
  },
  "bugs": {
    "url": "https://github.com/igorkowalczyk/igorkowalczyk.dev/issues"
