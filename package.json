  "devDependencies": {
    "@igorkowalczyk/eslint-config": "^3.2.1",
    "@igorkowalczyk/prettier-config": "^3.2.1",
    "@next/bundle-analyzer": "^16.2.6",
    "@tailwindcss/typography": "^0.5.19",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.0.0",
    "jiti": "^2.7.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
